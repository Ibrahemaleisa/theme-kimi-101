{# 
  Theme: theme-kimi-101 
  File: master.twig
  Description: The core layout of the luxury streetwear store.
#}
<!DOCTYPE html>
<html lang="{{ shop.language }}" dir="{{ shop.direction }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    
    {# Salla Mandatory Header Tags #}
    {{ salla_header() }}

    {# Fonts: Inter for minimal look #}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@100;200;300;400;500&display=swap" rel="stylesheet">

    {# Main Theme CSS #}
    <link rel="stylesheet" href="{{ asset('styles/theme.css') }}">

    <style>
        /* شاشة التحميل الأولية لضمان تجربة الـ Luxury قبل تحميل أي ملف */
        #intro-overlay {
            position: fixed;
            inset: 0;
            background: #000;
            z-index: 9999;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
        }
        .intro-brand {
            font-family: 'Inter', sans-serif;
            color: #fff;
            font-weight: 100;
            text-transform: uppercase;
            letter-spacing: 1em;
            font-size: clamp(1rem, 5vw, 2.5rem);
            text-align: center;
            opacity: 0;
            filter: blur(10px);
            animation: introAnimation 3.2s cubic-bezier(0.4, 0, 0.2, 1) forwards;
        }
        @keyframes introAnimation {
            10% { opacity: 0; filter: blur(15px); transform: scale(0.9); }
            45% { opacity: 1; filter: blur(0px); transform: scale(1); }
            80% { opacity: 1; filter: blur(0px); transform: scale(1); }
            100% { opacity: 0; filter: blur(10px); transform: scale(1.05); visibility: hidden; }
        }
    </style>
</head>

<body class="bg-[#000] text-[#f5f5f5] antialiased selection:bg-white selection:text-black">

    {# Landing Experience #}
    <div id="intro-overlay">
        <h1 class="intro-brand">{{ shop.name }}</h1>
    </div>

    {# Header Component #}
    {% component 'header' %}

    {# Main Content Area #}
    <main id="main-content" class="opacity-0 transition-opacity duration-[1200ms] min-h-screen">
        {% block content %}{% endblock %}
    </main>

    {# Footer Component #}
    {% component 'footer' %}

    {# Salla Mandatory Footer Tags #}
    {{ salla_footer() }}

    {# Theme Logic JS #}
    <script src="{{ asset('js/theme.js') }}"></script>
</body>
</html>
