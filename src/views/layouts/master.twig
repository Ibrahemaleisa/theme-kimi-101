<!DOCTYPE html>
<html lang="{{ shop.language.code }}" dir="{{ shop.language.dir }}">
<head>
    {{ salla_header }}
    <style>
        /* إخفاء أي عناصر إضافية قد تفرضها المنصة */
        .s-button-wrap, .s-cart-summary { border-radius: 0 !important; }
    </style>
    <link rel="stylesheet" href="{{ asset('styles/theme.css') }}">
</head>
<body class="bg-[#0a0a0a] text-[#f2f2f2] antialiased selection:bg-white selection:text-black">

    <div id="initial-reveal" class="fixed inset-0 z-[9999] bg-black flex items-center justify-center transition-all duration-[1.5s] ease-in-out">
        <div class="reveal-content text-center">
            <h1 class="text-2xl md:text-3xl tracking-[0.5em] font-light uppercase opacity-0 transition-all duration-[2s]" id="brand-name">
                {{ shop.name }}
            </h1>
        </div>
    </div>

    {% component 'header' %}

    <main class="min-h-screen opacity-0 transition-opacity duration-[2s]" id="site-wrapper">
        {% block content %}{% endblock %}
    </main>

    {% component 'footer' %}

    {{ salla_footer }}
    <script src="{{ asset('js/theme.js') }}"></script>
</body>
</html>
