{# 
  Component: Categories Grid
  Logic: Fetch main categories from Salla
#}
<section class="grid grid-cols-1 md:grid-cols-2 gap-4">
    {% for category in categories %}
        <a href="{{ category.url }}" class="group relative aspect-square md:aspect-[16/9] overflow-hidden bg-[#0d0d0d]">
            <img src="{{ category.image.url | default(asset('images/placeholder.png')) }}" 
                 alt="{{ category.name }}"
                 class="w-full h-full object-cover opacity-70 group-hover:opacity-100 group-hover:scale-105 transition-all duration-1000">
            
            <div class="absolute inset-0 flex items-center justify-center">
                <div class="text-center">
                    <h3 class="text-sm md:text-lg tracking-[0.6em] uppercase font-extralight group-hover:tracking-[0.8em] transition-all duration-700">
                        {{ category.name }}
                    </h3>
                    <span class="mt-4 block text-[8px] tracking-[0.3em] uppercase text-gray-500 opacity-0 group-hover:opacity-100 transition-all duration-700">Explore Collection</span>
                </div>
            </div>
        </a>
    {% endfor %}
</section>
