{# 
  Component: Marquee Banner
  Style: Minimal/Text-Based
#}
<div class="py-6 border-y border-[#1a1a1a] bg-black overflow-hidden flex">
    <div class="flex whitespace-nowrap animate-marquee">
        {% for i in 1..10 %}
            <span class="text-[10px] md:text-xs tracking-[0.5em] uppercase font-light mx-8 text-white/40">
                New Era of Streetwear &mdash; Worldwide Shipping &mdash; Limited Drops Only &mdash;
            </span>
        {% endfor %}
    </div>
</div>

<style>
    .animate-marquee {
        animation: marquee 40s linear infinite;
    }
    @keyframes marquee {
        0% { transform: translateX(0); }
        100% { transform: translateX(-50%); }
    }
</style>
