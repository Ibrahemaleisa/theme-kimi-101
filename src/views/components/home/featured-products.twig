<section class="section section-featured" data-animate="fade-up">
  <div class="container">
    <div class="section-header">
      <h2 class="section-title">Featured Collection</h2>
      <a href="{{ link('collection') }}" class="section-link">View All</a>
    </div>
    <div class="product-grid" data-grid="4">
      {% for product in products|slice(0, fields.limit|default(8)) %}
        {% include 'components.product.card' with {'product': product} %}
      {% endfor %}
    </div>
  </div>
</section>
