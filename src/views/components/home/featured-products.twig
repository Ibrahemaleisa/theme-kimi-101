{# 
  Component: Featured Products
  Logic: Loop through products provided by Salla context
#}
<div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-x-4 gap-y-12 md:gap-x-8 md:gap-y-20">
    {% for product in products %}
        {% component 'product-card' with { 'product': product } %}
    {% else %}
        {# حالة عدم وجود منتجات - Empty State #}
        {% for i in 1..4 %}
            <div class="animate-pulse">
                <div class="aspect-[3/4] bg-[#0d0d0d] mb-4"></div>
                <div class="h-2 bg-[#0d0d0d] w-1/2 mb-2"></div>
                <div class="h-2 bg-[#0d0d0d] w-1/4"></div>
            </div>
        {% endfor %}
    {% endfor %}
</div>
