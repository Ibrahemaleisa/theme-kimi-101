{# 
  Component: Header
  Style: Luxury Minimalist
#}
<header id="site-header" class="fixed top-0 left-0 w-full z-50 transition-all duration-700 py-8 px-6 md:px-12 flex justify-between items-center">
    
    {# Menu Icon (Left) #}
    <div class="flex-1">
        <button class="group flex flex-col space-y-1.5 focus:outline-none" aria-label="Menu">
            <span class="block w-6 h-[1px] bg-white transition-all duration-500 group-hover:w-9"></span>
            <span class="block w-9 h-[1px] bg-white transition-all duration-500"></span>
        </button>
    </div>

    {# Logo (Center) #}
    <div class="flex-1 text-center">
        <a href="{{ shop.url }}" class="inline-block">
            <h1 class="text-lg md:text-xl font-light tracking-[0.6em] uppercase transition-all duration-500 hover:opacity-60">
                {{ shop.name }}
            </h1>
        </a>
    </div>

    {# Search & Cart (Right) #}
    <div class="flex-1 flex justify-end items-center space-x-6 md:space-x-10">
        <a href="{{ url('/search') }}" class="hidden md:block hover:opacity-50 transition-opacity">
            <span class="text-[10px] tracking-[0.3em] uppercase font-light">{{ trans('common.search') }}</span>
        </a>
        
        <a href="{{ url('/cart') }}" class="group relative flex items-center">
            <span class="text-[10px] tracking-[0.3em] uppercase font-light group-hover:text-gray-400 transition-colors">
                {{ trans('common.cart') }}
            </h1>
            <span class="ml-2 text-[10px] font-light bg-white text-black px-1.5 py-0.5 rounded-full">
                {{ cart.count }}
            </span>
        </a>
    </div>
</header>
