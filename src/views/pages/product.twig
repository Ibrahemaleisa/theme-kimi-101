{# 
  Page: Product Details
  Path: src/views/pages/product.twig
#}
{% extends "layouts.master" %}

{% block content %}
<div class="container mx-auto px-6 pt-32 pb-20">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-16">
        
        {# Left: Product Images (6/12) #}
        <div class="lg:col-span-7 space-y-4">
            <div class="aspect-[3/4] bg-[#0d0d0d] overflow-hidden">
                <img src="{{ product.image.url }}" class="w-full h-full object-cover" alt="{{ product.name }}">
            </div>
            {# Grid for more images if available #}
            <div class="grid grid-cols-2 gap-4">
                {% for image in product.images %}
                    <div class="aspect-[3/4] bg-[#0d0d0d] overflow-hidden">
                        <img src="{{ image.url }}" class="w-full h-full object-cover" alt="{{ product.name }}">
                    </div>
                {% endfor %}
            </div>
        </div>

        {# Right: Product Details (5/12) #}
        <div class="lg:col-span-5 lg:sticky lg:top-32 h-fit space-y-10">
            <div class="space-y-4 border-b border-[#1a1a1a] pb-10">
                <h1 class="text-2xl md:text-3xl font-light tracking-[0.2em] uppercase">{{ product.name }}</h1>
                <div class="flex items-center space-x-4">
                    <span class="text-xl font-medium tracking-tight">{{ product.price | money }}</span>
                    {% if product.on_sale %}
                        <span class="text-sm text-gray-600 line-through">{{ product.regular_price | money }}</span>
                    {% endif %}
                </div>
            </div>

            {# Options (Sizes/Colors) #}
            <div class="space-y-8">
                {% for option in product.options %}
                    <div class="space-y-4">
                        <span class="text-[10px] tracking-[0.3em] uppercase text-gray-500">Select {{ option.name }}</span>
                        <div class="flex flex-wrap gap-3">
                            {% for value in option.values %}
                                <button class="px-6 py-3 border border-[#1a1a1a] text-[10px] tracking-widest uppercase hover:border-white transition-all">
                                    {{ value.name }}
                                </button>
                            {% endfor %}
                        </div>
                    </div>
                {% endfor %}
            </div>

            {# Action Button #}
            <div class="pt-10 space-y-4">
                <button onclick="salla.cart.addItem({id: {{ product.id }}})" 
                        class="w-full bg-white text-black py-5 text-[10px] tracking-[0.5em] uppercase font-bold hover:bg-[#f0f0f0] transition-colors">
                    Add to Bag
                </button>
                <p class="text-[9px] text-center text-gray-600 tracking-[0.1em] uppercase py-4">
                    Free Worldwide Shipping on all Season 01 drops.
                </p>
            </div>

            {# Description Accordion (Minimal) #}
            <div class="border-t border-[#1a1a1a] pt-6">
                <details class="group" open>
                    <summary class="list-none cursor-pointer flex justify-between items-center">
                        <span class="text-[10px] tracking-[0.3em] uppercase font-light">Product Description</span>
                        <span class="text-xl font-light group-open:rotate-45 transition-transform">+</span>
                    </summary>
                    <div class="pt-6 text-gray-400 text-xs leading-relaxed font-light tracking-wide">
                        {{ product.description | raw }}
                    </div>
                </details>
            </div>
        </div>
    </div>
</div>
{% endblock %}
