{# 
  Page: Shopping Bag
  Path: src/views/pages/cart.twig
#}
{% extends "layouts.master" %}

{% block content %}
<div class="container mx-auto px-6 pt-40 pb-20">
    <div class="max-w-5xl mx-auto">
        <h1 class="text-xl tracking-[0.5em] uppercase font-light mb-16 border-b border-[#1a1a1a] pb-8">Your Bag ({{ cart.items | length }})</h1>

        {% if cart.items %}
            <div class="grid grid-cols-1 lg:grid-cols-12 gap-16">
                
                {# Items List #}
                <div class="lg:col-span-7 space-y-8">
                    {% for item in cart.items %}
                        <div class="flex space-x-6 pb-8 border-b border-[#1a1a1a] group" id="item-{{ item.id }}">
                            <div class="w-24 h-32 bg-[#0d0d0d] overflow-hidden flex-shrink-0">
                                <img src="{{ item.product.image.url }}" alt="{{ item.product.name }}" class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-700">
                            </div>
                            
                            <div class="flex-1 flex flex-col justify-between py-1">
                                <div class="flex justify-between items-start">
                                    <div>
                                        <h3 class="text-xs tracking-widest uppercase font-medium">{{ item.product.name }}</h3>
                                        <p class="text-[9px] text-gray-500 tracking-widest uppercase mt-2">
                                            Size: {{ item.options_text | default('Standard') }}
                                        </p>
                                    </div>
                                    <button onclick="salla.cart.deleteItem({{ item.id }})" class="text-[10px] uppercase text-gray-600 hover:text-white transition-colors">Remove</button>
                                </div>
                                
                                <div class="flex justify-between items-end mt-4">
                                    {# Quantity Controller #}
                                    <div class="flex items-center border border-[#1a1a1a] px-3 py-1 space-x-4">
                                        <button onclick="salla.cart.updateItemQty({{ item.id }}, {{ item.quantity - 1 }})" class="text-xs hover:text-gray-400">-</button>
                                        <span class="text-[10px] font-light">{{ item.quantity }}</span>
                                        <button onclick="salla.cart.updateItemQty({{ item.id }}, {{ item.quantity + 1 }})" class="text-xs hover:text-gray-400">+</button>
                                    </div>
                                    <span class="text-xs font-medium">{{ item.total | money }}</span>
                                </div>
                            </div>
                        </div>
                    {% endfor %}
                </div>

                {# Summary #}
                <div class="lg:col-span-5 h-fit bg-[#0a0a0a] border border-[#1a1a1a] p-10 space-y-8">
                    <h2 class="text-xs tracking-[0.3em] uppercase border-b border-[#1a1a1a] pb-4">Order Summary</h2>
                    
                    <div class="space-y-4">
                        <div class="flex justify-between text-[10px] tracking-widest text-gray-400 uppercase">
                            <span>Subtotal</span>
                            <span>{{ cart.sub_total | money }}</span>
                        </div>
                        <div class="flex justify-between text-[10px] tracking-widest text-gray-400 uppercase">
                            <span>Shipping</span>
                            <span>Calculated at next step</span>
                        </div>
                        <div class="flex justify-between text-sm tracking-widest uppercase pt-4 border-t border-[#1a1a1a]">
                            <span>Total</span>
                            <span>{{ cart.total | money }}</span>
                        </div>
                    </div>

                    <a href="{{ url('/checkout') }}" class="block w-full bg-white text-black text-center py-5 text-[10px] tracking-[0.5em] uppercase font-bold hover:bg-[#e0e0e0] transition-colors">
                        Proceed to Checkout
                    </a>
                    
                    <p class="text-[8px] text-center text-gray-600 tracking-widest leading-relaxed uppercase">
                        Complimentary shipping and returns on all seasonal drops. Taxes included.
                    </p>
                </div>

            </div>
        {% else %}
            <div class="text-center py-40 space-y-8">
                <p class="text-[10px] tracking-[0.5em] uppercase text-gray-600">Your bag is currently empty.</p>
                <a href="{{ url('/products') }}" class="inline-block border border-white px-12 py-4 text-[9px] tracking-[0.4em] uppercase hover:bg-white hover:text-black transition-all">Start Shopping</a>
            </div>
        {% endif %}
    </div>
</div>
{% endblock %}
