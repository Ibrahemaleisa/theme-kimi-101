<footer class="site-footer">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand">
        {% if settings.logo %}
          <img src="{{ settings.logo | img_url: '200x' }}" alt="{{ shop.name }}" class="footer-logo" width="140" height="46" loading="lazy">
        {% else %}
          <h3 class="footer-logo-text">{{ shop.name }}</h3>
        {% endif %}
        <p class="footer-tagline">Curated luxury for the discerning few.</p>
        <div class="social-links">
          {% if settings.social_instagram %}
            <a href="{{ settings.social_instagram }}" target="_blank" rel="noopener" aria-label="Instagram">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
                <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
                <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
              </svg>
            </a>
          {% endif %}
          {% if settings.social_twitter %}
            <a href="{{ settings.social_twitter }}" target="_blank" rel="noopener" aria-label="Twitter">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z"></path>
              </svg>
            </a>
          {% endif %}
        </div>
      </div>
      
      <div class="footer-menu">
        <h4 class="footer-title">Shop</h4>
        <ul>
          {% for link in linklists.footer.links %}
            <li><a href="{{ link.url }}">{{ link.title }}</a></li>
          {% endfor %}
        </ul>
      </div>
      
      <div class="footer-menu">
        <h4 class="footer-title">Support</h4>
        <ul>
          <li><a href="{{ store.url }}/contact">Contact</a></li>
          <li><a href="{{ store.url }}/shipping">Shipping</a></li>
          <li><a href="{{ store.url }}/returns">Returns</a></li>
          <li><a href="{{ store.url }}/faq">FAQ</a></li>
        </ul>
      </div>
      
      <div class="footer-newsletter">
        <h4 class="footer-title">Stay Updated</h4>
        <p class="footer-text">Subscribe for exclusive drops and early access.</p>
        <form class="newsletter-form" action="{{ store.url }}/newsletter/subscribe" method="post">
          <input type="email" name="email" placeholder="Enter your email" required class="newsletter-input">
          <button type="submit" class="newsletter-btn">Subscribe</button>
        </form>
      </div>
    </div>
    
    <div class="footer-bottom">
      <p class="copyright">&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.</p>
      <div class="payment-icons">
        <span class="payment-icon">Visa</span>
        <span class="payment-icon">MC</span>
        <span class="payment-icon">Amex</span>
        <span class="payment-icon">Apple Pay</span>
      </div>
    </div>
  </div>
</footer>
