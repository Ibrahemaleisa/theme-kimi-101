<section class="section section-cart">
  <div class="container">
    <h1 class="page-title">Shopping Cart</h1>
    
    {% if cart.items.size > 0 %}
      <form class="cart-form" action="{{ store.url }}/cart" method="post" data-cart-form>
        <div class="cart-layout">
          <div class="cart-items">
            {% for item in cart.items %}
              <div class="cart-item" data-cart-item="{{ item.id }}">
                <div class="item-image">
                  <img src="{{ item.image | img_url: '200x200', crop: 'center' }}" alt="{{ item.title }}" loading="lazy">
                </div>
                <div class="item-details">
                  <h3 class="item-title">
                    <a href="{{ item.url }}">{{ item.product.title }}</a>
                  </h3>
                  {% if item.variant.title != 'Default Title' %}
                    <p class="item-variant">{{ item.variant.title }}</p>
                  {% endif %}
                  <div class="item-price">{{ item.price | money }}</div>
                </div>
                <div class="item-quantity">
                  <div class="quantity-selector">
                    <button type="button" class="qty-btn" data-qty-update="{{ item.id }}" data-action="minus">-</button>
                    <input type="number" name="updates[{{ item.id }}]" value="{{ item.quantity }}" min="0" class="qty-input" data-qty-input>
                    <button type="button" class="qty-btn" data-qty-update="{{ item.id }}" data-action="plus">+</button>
                  </div>
                </div>
                <div class="item-total">{{ item.total | money }}</div>
                <button type="button" class="item-remove" data-remove-item="{{ item.id }}" aria-label="Remove item">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <path d="M18 6 6 18"></path>
                    <path d="m6 6 12 12"></path>
                  </svg>
                </button>
              </div>
            {% endfor %}
          </div>
          
          <div class="cart-summary" data-animate="fade-left">
            <h2 class="summary-title">Order Summary</h2>
            <div class="summary-row">
              <span>Subtotal</span>
              <span data-cart-subtotal>{{ cart.total | money }}</span>
            </div>
            <div class="summary-row">
              <span>Shipping</span>
              <span class="text-muted">Calculated at checkout</span>
            </div>
            <div class="summary-row total">
              <span>Total</span>
              <span data-cart-total>{{ cart.total | money }}</span>
            </div>
            <button type="submit" name="checkout" class="btn btn-primary btn-large btn-full">Proceed to Checkout</button>
            <a href="{{ store.url }}" class="btn btn-secondary btn-full">Continue Shopping</a>
          </div>
        </div>
      </form>
    {% else %}
      <div class="cart-empty" data-animate="fade-up">
        <div class="empty-icon">
          <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
            <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"></path>
            <path d="M3 6h18"></path>
            <path d="M16 10a4 4 0 0 1-8 0"></path>
          </svg>
        </div>
        <h2 class="empty-title">Your cart is empty</h2>
        <p class="empty-text">Discover our curated collection of luxury pieces.</p>
        <a href="{{ store.url }}/collections/all" class="btn btn-primary">Start Shopping</a>
      </div>
    {% endif %}
  </div>
</section>
