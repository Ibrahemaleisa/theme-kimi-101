{
  "name": "Luxury Streetwear Theme",
  "version": "1.0.0",
  "author": "Custom",
  "description": "Modern Luxury Streetwear Theme for Salla",
  "settings": [
    {
      "id": "colors",
      "label": "الألوان",
      "elements": [
        {
          "id": "primary_color",
          "label": "اللون الرئيسي",
          "type": "color",
          "default": "#1a1a1a"
        },
        {
          "id": "secondary_color",
          "label": "اللون الثانوي",
          "type": "color",
          "default": "#f5f5f0"
        },
        {
          "id": "accent_color",
          "label": "لون التمييز",
          "type": "color",
          "default": "#ffffff"
        }
      ]
    },
    {
      "id": "header",
      "label": "الهيدر",
      "elements": [
        {
          "id": "topnav_is_dark",
          "label": "هيدر داكن",
          "type": "toggle",
          "default": true
        },
        {
          "id": "sticky_header",
          "label": "هيدر ثابت عند التمرير",
          "type": "toggle",
          "default": true
        }
      ]
    },
    {
      "id": "intro",
      "label": "شاشة البداية",
      "elements": [
        {
          "id": "show_intro",
          "label": "إظهار شاشة البداية",
          "type": "toggle",
          "default": true
        }
      ]
    }
  ],
  "features": [
    "topnav_is_dark",
    "sticky_header"
  ]
}

